   "source": [
    "sentence = \"The eiffel tower was built from 1887 to 1889 by French engineer Kaustubh Naithani. his company specilised in building metal frame works\"\n",
    "\n",
    "import nltk\n",
    "\n",
    "words = nltk.word_tokenize(sentence)\n",
    "\n",
    "tagged_element = nltk.pos_tag(words)\n",
    "\n",
    "nltk.ne_chunk(tagged_element).draw()\n"
   ]
  }
